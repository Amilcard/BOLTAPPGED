# ============================================
# Variables d'environnement — GED App
# Copier ce fichier : cp .env.example .env.local
# Remplir toutes les valeurs avant de démarrer
# ============================================

# ── Supabase ────────────────────────────────
# Dashboard : supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Auth (NextAuth) ──────────────────────────
# Générer : openssl rand -base64 32
NEXTAUTH_SECRET=votre-secret-aleatoire-32-caracteres-minimum
# URL publique de l'app (ex: https://monapp.vercel.app, http://localhost:3000 en dev)
NEXTAUTH_URL=http://localhost:3000

# ── Stripe ──────────────────────────────────
# Dashboard : dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Dashboard : dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (Resend) ───────────────────────────
# Dashboard : resend.com/api-keys
EMAIL_SERVICE_API_KEY=re_...
ADMIN_NOTIFICATION_EMAIL=admin@groupeetdecouverte.fr

# ── Build ────────────────────────────────────
NEXT_DISABLE_STATIC_PAGE_GENERATION=true

# ── Virement bancaire ───────────────────────
ORG_BANK_HOLDER=GROUPE ET DECOUVERTE
ORG_BANK_IBAN=
ORG_BANK_BIC=
ORG_BANK_BRANCH=

# ── Cron / Sécurité ─────────────────────────
CRON_SECRET=

# ── URLs publiques ──────────────────────────
NEXT_PUBLIC_APP_URL=https://app.groupeetdecouverte.fr
NEXT_PUBLIC_SENTRY_DSN=

# ── Captcha Turnstile (Cloudflare, RGPD-friendly) ──
# Dashboard : dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
