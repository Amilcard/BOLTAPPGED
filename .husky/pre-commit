echo "[GED pre-commit] Vérifications en cours..."

# 1. TypeScript
echo "[1/3] TypeScript..."
npx tsc --noEmit --pretty 2>&1
if [ $? -ne 0 ]; then
  echo "[FAIL] Erreurs TypeScript. Corriger avant de committer."
  echo "       Contournement légitime uniquement : git commit --no-verify"
  exit 1
fi

# 2. ESLint sur fichiers staged uniquement
#
# NB : --no-ignore contourne un bug ESLint 8.x où les paths Next.js
# dynamic routes (app/api/.../[param]/route.ts) sont signalés comme
# "File ignored by default" à cause de l'interprétation des brackets
# comme glob character class. Le .eslintignore ne couvre que
# supabase/** — non-modifié dans les routes app/, donc --no-ignore
# sûr ici. Les .eslintrc.ignorePatterns (.next/, scripts/, etc.) sont
# aussi bypassés mais ces dossiers ne sont pas staged normalement.
echo "[2/3] ESLint..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)
if [ -n "$STAGED" ]; then
  echo "$STAGED" | xargs npx eslint --no-ignore --max-warnings 0 2>&1
  if [ $? -ne 0 ]; then
    echo "[FAIL] Erreurs ESLint."
    exit 1
  fi
fi

# 3. Tests unitaires rapides
echo "[3/3] Tests unitaires..."
npx jest 'tests/unit' --passWithNoTests --silent 2>&1
if [ $? -ne 0 ]; then
  echo "[FAIL] Tests unitaires en échec."
  exit 1
fi

echo "[GED pre-commit] OK"
